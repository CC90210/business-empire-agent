# .env.agents.template
# Do NOT commit the actual .env.agents to Github.
# Store your MCP server keys and external API access tokens here safely.
# All agents (Claude Code, Anti-Gravity, Gemini CLI, Blackbox) read from .env.agents

# === MCP SERVER CREDENTIALS ===

# Supabase Management Token (for MCP server)
SUPABASE_ACCESS_TOKEN=your_token_here

# Supabase (Bravo - Main Command Center)
BRAVO_SUPABASE_URL=https://xxx.supabase.co
BRAVO_SUPABASE_ANON_KEY=your_key_here
BRAVO_SUPABASE_SERVICE_ROLE_KEY=your_key_here

# Supabase (Oasis-AI-Platform)
OASIS_SUPABASE_URL=https://xxx.supabase.co
OASIS_SUPABASE_ANON_KEY=your_key_here
OASIS_SUPABASE_SERVICE_ROLE_KEY=your_key_here

# Supabase (Nostalgic-Requests)
NOSTALGIC_SUPABASE_URL=https://xxx.supabase.co
NOSTALGIC_SUPABASE_ANON_KEY=your_key_here
NOSTALGIC_SUPABASE_SERVICE_ROLE_KEY=your_key_here

# GitHub (For the GitHub MCP Server)
GITHUB_PERSONAL_ACCESS_TOKEN=your_pat_here

# Stripe (Payment Management MCP)
STRIPE_SECRET_KEY=your_sk_here

# Late (Social Media Posting MCP)
LATE_API_KEY=your_key_here

# n8n Supergateway (Workflow Automation MCP)
N8N_BEARER_TOKEN=your_jwt_here

# === BRIDGE & INTEGRATIONS ===

# Telegram (CLI Bridge)
TELEGRAM_BOT_TOKEN=your_token_here

# Gmail (AI Oasis Account - SMTP/API)
GMAIL_USER=your_email_here
GMAIL_APP_PASSWORD=your_app_password_here

# Notion (Bravo Empire Hub)
NOTION_API_KEY=your_key_here
NOTION_HOME_PAGE_ID=your_id_here
NOTION_DAILY_TASKS_ID=your_id_here
NOTION_WEEKLY_TASKS_ID=your_id_here
NOTION_MONTHLY_TASKS_ID=your_id_here
NOTION_WEEKDAY_RITUAL_ID=your_id_here
NOTION_WEEKEND_RITUAL_ID=your_id_here
